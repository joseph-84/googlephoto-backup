# ===================================================
# Google Photos → Drive 자동 이관 시스템 환경 설정
# 이 파일을 복사하여 .env 로 저장 후 값을 채워주세요
# cp .env.example .env
# ===================================================

# 슬랙 알림 (선택사항 - 비워두면 알림 비활성화)
SLACK_WEBHOOK_URL=

# 타임존 설정 (크론 스케줄 기준)
TZ=Asia/Seoul

# 로그 레벨: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 한 번 실행 시 계정당 최대 처리 건수 (0 = 무제한)
MAX_ITEMS_PER_RUN=100

# 드라이브 업로드 후 포토 삭제 여부 (true/false)
# false 로 설정 시 드라이브 업로드만 수행하고 포토는 유지 (테스트용)
DELETE_FROM_PHOTOS=true

# 사진 다운로드 임시 디렉토리 (컨테이너 내부 경로)
TEMP_DIR=/tmp/photo_backup
